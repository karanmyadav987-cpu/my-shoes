<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ShoeStore</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, Helvetica, sans-serif;
        }

        body {
            background: #f5f5f5;
        }

        header {
            background: #111;
            color: white;
            padding: 15px 8%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
        }

        .logo {
            font-size: 28px;
            font-weight: bold;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin-left: 25px;
            transition: .3s;
        }

        nav a:hover {
            color: #ff6600;
        }

        .cart {
            background: #ff6600;
            padding: 8px 15px;
            border-radius: 20px;
        }

        .hero {
            height: 90vh;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 8%;
            background: linear-gradient(135deg, #222, #444);
            color: white;
        }

        .hero-text {
            width: 50%;
        }

        .hero h1 {
            font-size: 60px;
            margin-bottom: 20px;
        }

        .hero p {
            font-size: 18px;
            margin-bottom: 30px;
        }

        .hero button {
            padding: 15px 35px;
            font-size: 18px;
            border: none;
            background: #ff6600;
            color: white;
            cursor: pointer;
            border-radius: 30px;
            transition: .3s;
        }

        .hero button:hover {
            background: white;
            color: #ff6600;
        }

        .hero img {
            width: 500px;
            animation: float 3s infinite ease-in-out;
        }

        @keyframes float {

            0%,
            100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-20px);
            }
        }

        .products {
            padding: 80px 8%;
        }

        .products h2 {
            text-align: center;
            font-size: 40px;
            margin-bottom: 40px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 30px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, .1);
            text-align: center;
            transition: .4s;
        }

        .card:hover {
            transform: translateY(-10px);
        }

        .card img {
            width: 220px;
            height: 180px;
            object-fit: contain;
        }

        .card h3 {
            margin: 15px 0;
        }

        .price {
            font-size: 22px;
            color: #ff6600;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .card button {
            padding: 12px 25px;
            border: none;
            background: #111;
            color: white;
            cursor: pointer;
            border-radius: 25px;
        }

        .card button:hover {
            background: #ff6600;
        }

        .about {
            padding: 80px 8%;
            background: white;
            text-align: center;
        }

        .about h2 {
            font-size: 40px;
            margin-bottom: 20px;
        }

        .contact {
            padding: 80px 8%;
            text-align: center;
        }

        input,
        textarea {
            width: 70%;
            padding: 15px;
            margin: 10px;
            border: 1px solid gray;
            border-radius: 8px;
        }

        textarea {
            height: 150px;
        }

        .contact button {
            padding: 15px 40px;
            background: #ff6600;
            color: white;
            border: none;
            cursor: pointer;
            font-size: 18px;
        }

        footer {
            background: #111;
            color: white;
            padding: 20px;
            text-align: center;
            margin-top: 40px;
        }

        @media(max-width:900px) {

            .hero {
                flex-direction: column;
                text-align: center;
                height: auto;
                padding: 60px 8%;
            }

            .hero-text {
                width: 100%;
            }

            .hero img {
                width: 100%;
                max-width: 400px;
                margin-top: 40px;
            }

            .hero h1 {
                font-size: 40px;
            }

            nav {
                display: none;
            }

        }
    </style>

</head>

<body>

    <header>

        <div class="logo">👟 ShoeStore</div>

        <nav>
            <a href="#">Home</a>
            <a href="#products">Products</a>
            <a href="#about">About</a>
            <a href="#contact">Contact</a>
        </nav>

        <div class="cart">
            🛒 Cart :
            <span id="cart">0</span>
        </div>

    </header>

    <section class="hero">

        <div class="hero-text">
            <h1>Step Into Style</h1>

            <p>
                Discover premium sneakers and sports shoes with the latest fashion,
                comfort, and performance.
            </p>

            <button onclick="scrollToProducts()">
                Shop Now
            </button>

        </div>

        <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=700" alt="shoe">

    </section>

    <section class="products" id="products">

        <h2>Featured Shoes</h2>

        <div class="grid">

            <div class="card">

                <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=400">

                <h3>Nike Air Max</h3>

                <div class="price">$120</div>

                <button onclick="addCart()">
                    Add to Cart
                </button>

            </div>

            <div class="card">

                <img src="https://images.unsplash.com/photo-1600185365483-26d7a4cc7519?w=400">

                <h3>Adidas Runner</h3>

                <div class="price">$110</div>

                <button onclick="addCart()">
                    Add to Cart
                </button>

            </div>

            <div class="card">

                <img src="https://images.unsplash.com/photo-1525966222134-fcfa99b8ae77?w=400">

                <h3>Puma Sports</h3>

                <div class="price">$95</div>

                <button onclick="addCart()">
                    Add to Cart
                </button>

            </div>

            <div class="card">

                <img src="https://images.unsplash.com/photo-1543508282-6319a3e2621f?w=400">

                <h3>Jordan Retro</h3>

                <div class="price">$150</div>

                <button onclick="addCart()">
                    Add to Cart
                </button>

            </div>

        </div>

    </section>

    <section class="about" id="about">

        <h2>About Us</h2>

        <p>

            We provide premium branded shoes with excellent quality,
            comfortable design, and fast delivery.

        </p>

    </section>

    <section class="contact" id="contact">

        <h2>Contact Us</h2>

        <input type="text" placeholder="Your Name">

        <input type="email" placeholder="Email">

        <textarea placeholder="Message"></textarea>

        <br>

        <button>Send Message</button>

    </section>

    <footer>

        © 2026 ShoeStore | Designed with ❤️

    </footer>

    <script>

        let cart = 0;

        function addCart() {

            cart++;

            document.getElementById("cart").innerHTML = cart;

            alert("Added to Cart!");

        }

        function scrollToProducts() {

            document.getElementById("products").scrollIntoView({

                behavior: "smooth"

            });

        }

    </script>

</body>

</html>